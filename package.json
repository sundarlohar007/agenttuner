{
	"name": "agenttuner",
	"version": "0.1.0",
	"description": "Your CLAUDE.md is wasting tokens. Auto-optimize your AI coding agent configs from real session data.",
	"type": "module",
	"main": "dist/cli.js",
	"module": "dist/cli.js",
	"types": "dist/cli.d.ts",
	"bin": {
		"agenttuner": "./bin/agenttuner.js"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/cli.d.ts",
				"default": "./dist/cli.js"
			},
			"require": {
				"types": "./dist/cli.d.cts",
				"default": "./dist/cli.cjs"
			}
		}
	},
	"files": [
		"dist",
		"bin"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepublishOnly": "pnpm build && pnpm test"
	},
	"keywords": [
		"claude",
		"claude-code",
		"cursor",
		"codex",
		"ai-agent",
		"agent-config",
		"claude-md",
		"agents-md",
		"token-optimizer",
		"cli"
	],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yourname/agenttuner.git"
	},
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"commander": "^14.0.3",
		"nanospinner": "^1.2.2",
		"picocolors": "^1.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
